<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📱 MotionSMS Gateway"
            android:textColor="#58A6FF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SMS → Telegram Bot"
            android:textColor="#8B949E"
            android:textSize="13sp"
            android:layout_marginBottom="24dp"/>

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#161B22"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status: "
                android:textColor="#8B949E"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔴 Service বন্ধ"
                android:textColor="#F85149"
                android:textSize="15sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Bot Token -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bot Token (SMS Bot)"
            android:textColor="#8B949E"
            android:textSize="13sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etBotToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="1234567890:ABCdef..."
            android:textColor="#C9D1D9"
            android:textColorHint="#484F58"
            android:background="#161B22"
            android:padding="14dp"
            android:inputType="text"
            android:singleLine="true"
            android:layout_marginBottom="16dp"/>

        <!-- Chat ID -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="তোমার Telegram ID (Chat ID)"
            android:textColor="#8B949E"
            android:textSize="13sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etChatId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="6462244447"
            android:textColor="#C9D1D9"
            android:textColorHint="#484F58"
            android:background="#161B22"
            android:padding="14dp"
            android:inputType="number"
            android:singleLine="true"
            android:layout_marginBottom="20dp"/>

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="💾 Save Config"
            android:backgroundTint="#238636"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="10dp"/>

        <!-- Start Button -->
        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="▶ Start Service"
            android:backgroundTint="#1F6FEB"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="10dp"/>

        <!-- Stop Button -->
        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="⏹ Stop Service"
            android:backgroundTint="#DA3633"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp"/>

        <!-- Info -->
        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ℹ️ Service start হলে phone restart এও চালু থাকবে।\nSMS আসলে automatically Telegram Bot এ পাঠাবে।"
            android:textColor="#8B949E"
            android:textSize="12sp"
            android:lineSpacingExtra="4dp"
            android:background="#161B22"
            android:padding="14dp"/>

    </LinearLayout>
</ScrollView>
